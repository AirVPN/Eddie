{
    "version": "0.2.0",
    "configurations": [        
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",            
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net10.0/win-x64/Eddie-CLI.dll",
            "args": [
                "path.tools=${workspaceFolder}/../../deploy/windows_{@arch}",
                "path.resources=${workspaceFolder}/../../resources",
                "path=home",
                "webui.enabled=true"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "stopAtEntry": false
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach",
            "processName": "Eddie-CLI.exe"
        }
    ]
}